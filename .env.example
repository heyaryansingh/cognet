# Supabase — from project dashboard (or `supabase start` output for local dev)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe test-mode only in local development. Never expose this key to the browser.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
CRON_SECRET=
COGNET_SIGNING_PRIVATE_KEY=
COGNET_SIGNING_KEY_ID=
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Comma-separated actor handles allowed to use /admin moderation (set to the
# operator's registered handle at deploy time).
ADMIN_HANDLES=aryan

# Vercel sends this secret as Authorization: Bearer <CRON_SECRET> to cron routes.
# In production set every value above in the Vercel project, never in this file.
